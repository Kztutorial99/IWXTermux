<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MaterialComponents.DayNight.TermuxPrimaryActivity" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/iwx_accent_green</item>
        <item name="colorPrimaryVariant">@color/iwx_accent_cyan</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/iwx_bg_secondary</item>
        <item name="colorSecondaryVariant">@color/iwx_bg_primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/iwx_bg_secondary</item>
        <item name="colorOnSurface">@color/iwx_text_primary</item>
        <item name="colorBackground">@color/iwx_bg_primary</item>
        <item name="colorOnBackground">@color/iwx_text_primary</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/iwx_bg_primary</item>
        <item name="android:navigationBarColor">@color/iwx_bg_primary</item>
        <item name="android:textColorPrimary">@color/iwx_text_primary</item>
        <item name="android:textColorLink">@color/iwx_accent_cyan</item>
        <item name="android:textColorSecondary">@color/iwx_text_secondary</item>
        <item name="android:windowBackground">@color/iwx_bg_primary</item>
    </style>

    <style name="Theme.AppCompat.TermuxReportActivity" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimaryDark">@color/iwx_accent_green</item>
        <item name="colorPrimary">@color/iwx_accent_green</item>
        <item name="android:windowBackground">@color/iwx_bg_primary</item>
        <item name="android:textColorPrimary">@color/iwx_text_primary</item>
    </style>

    <style name="Theme.AppCompat.TermuxTextIOActivity" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimaryDark">@color/iwx_accent_green</item>
        <item name="colorPrimary">@color/iwx_accent_green</item>
        <item name="android:windowBackground">@color/iwx_bg_primary</item>
        <item name="android:textColorPrimary">@color/iwx_text_primary</item>
    </style>

    <style name="Toolbar.Title" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/iwx_text_primary</item>
    </style>

    <style name="ViewDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginTop">@dimen/activity_vertical_margin</item>
        <item name="android:layout_marginBottom">@dimen/activity_vertical_margin</item>
        <item name="android:background">@color/iwx_divider</item>
    </style>
</resources>
