<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="Theme.Termux" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/iwx_bg_primary</item>
        <item name="android:navigationBarColor">@color/iwx_bg_primary</item>
        <item name="colorPrimary">@color/iwx_accent_green</item>
        <item name="colorPrimaryVariant">@color/iwx_accent_cyan</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/iwx_bg_secondary</item>
        <item name="colorOnSecondary">@color/iwx_text_primary</item>
        <item name="colorSurface">@color/iwx_bg_secondary</item>
        <item name="colorOnSurface">@color/iwx_text_primary</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>
    </style>

    <style name="Theme.Termux.Black" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="colorPrimary">@color/iwx_accent_cyan</item>
        <item name="colorPrimaryVariant">@color/iwx_accent_green</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>

    <style name="TermuxAlertDialogStyle" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorAccent">@color/iwx_accent_green</item>
        <item name="android:textColorPrimary">@color/iwx_text_primary</item>
    </style>

    <style name="DrawerButtonStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/drawer_btn_bg</item>
        <item name="android:textColor">@color/iwx_text_primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

</resources>
