<com.termux.app.terminal.TermuxActivityRootView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_termux_root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="false">

    <!-- Material 3 TopAppBar via Compose -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/top_bar_compose_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <RelativeLayout
        android:id="@+id/activity_termux_root_relative_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="3dp"
        android:layout_marginVertical="0dp"
        android:orientation="vertical">

        <androidx.drawerlayout.widget.DrawerLayout
            android:id="@+id/drawer_layout"
            android:layout_width="match_parent"
            android:layout_alignParentTop="true"
            android:layout_above="@+id/terminal_toolbar_view_pager"
            android:layout_height="match_parent">

            <!-- Terminal View -->
            <com.termux.view.TerminalView
                android:id="@+id/terminal_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:defaultFocusHighlightEnabled="false"
                android:focusableInTouchMode="true"
                android:scrollbarThumbVertical="@drawable/terminal_scroll_shape"
                android:scrollbars="vertical"
                tools:ignore="UnusedAttribute" />

            <!-- LEFT DRAWER — Session List -->
            <LinearLayout
                android:id="@+id/left_drawer"
                android:layout_width="280dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:background="@color/iwx_bg_drawer"
                android:orientation="vertical"
                android:elevation="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:background="@color/iwx_bg_drawer_header"
                    android:paddingStart="20dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="36dp"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IWXTermux"
                            android:textColor="@color/iwx_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="7dp"
                                android:layout_height="7dp"
                                android:background="@drawable/dot_active"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Terminal Ready"
                                android:textColor="@color/iwx_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="v0.118.3"
                            android:textColor="@color/iwx_text_hint"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/settings_button"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:src="@drawable/ic_settings"
                        android:background="@drawable/icon_btn_bg"
                        android:contentDescription="@string/action_open_settings"
                        android:padding="8dp"
                        android:tint="@color/iwx_text_secondary" />
                </RelativeLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="6dp"
                    android:text="SESSIONS"
                    android:textColor="@color/iwx_text_hint"
                    android:textSize="10sp"
                    android:letterSpacing="0.15" />

                <ListView
                    android:id="@+id/terminal_sessions_list"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:choiceMode="singleChoice"
                    android:longClickable="true"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="0dp"
                    android:scrollbars="none" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/iwx_divider"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@color/iwx_bg_drawer"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <Button
                        android:id="@+id/toggle_keyboard_button"
                        style="@style/DrawerButtonStyle"
                        android:layout_marginEnd="6dp"
                        android:text="Keyboard" />

                    <Button
                        android:id="@+id/new_session_button"
                        style="@style/DrawerButtonStyle"
                        android:layout_marginStart="6dp"
                        android:text="New Session" />
                </LinearLayout>

            </LinearLayout>

            <!-- RIGHT DRAWER — Quick Actions + IWX Banner (Compose) -->
            <FrameLayout
                android:id="@+id/right_drawer"
                android:layout_width="270dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:background="@color/iwx_bg_primary"
                android:elevation="8dp">

                <androidx.compose.ui.platform.ComposeView
                    android:id="@+id/right_drawer_compose_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

        </androidx.drawerlayout.widget.DrawerLayout>

        <androidx.viewpager.widget.ViewPager
            android:id="@+id/terminal_toolbar_view_pager"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="37.5dp"
            android:background="@color/iwx_bg_secondary"
            android:layout_alignParentBottom="true" />

    </RelativeLayout>

    <View
        android:id="@+id/activity_termux_bottom_space_view"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/transparent" />

</com.termux.app.terminal.TermuxActivityRootView>
